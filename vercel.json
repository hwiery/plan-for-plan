{
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "env": {
    "GOOGLE_GEMINI_API_KEY": "@gemini-api-key",
    "DATABASE_URL": "@database-url",
    "NEXTAUTH_SECRET": "@nextauth-secret",
    "NEXTAUTH_URL": "@nextauth-url",
    "GOOGLE_CLIENT_ID": "@google-client-id",
    "GOOGLE_CLIENT_SECRET": "@google-client-secret"
  },
  "build": {
    "env": {
      "GOOGLE_GEMINI_API_KEY": "@gemini-api-key",
      "DATABASE_URL": "@database-url",
      "NEXTAUTH_SECRET": "@nextauth-secret"
    }
  }
}